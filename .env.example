# OneCLI proxy port (do not change unless OneCLI is configured differently)
ONECLI_PORT=4891

# Web UI binding (127.0.0.1 = localhost only, never change to 0.0.0.0)
WEB_HOST=127.0.0.1
WEB_PORT=3080

# Telegram bot token (set after running /add-telegram)
# TELEGRAM_TOKEN=

# Node environment
NODE_ENV=production
